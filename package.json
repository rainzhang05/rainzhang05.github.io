{
  "name": "rainzhang-portfolio",
  "version": "2.0.0",
  "private": true,
  "description": "Rain Zhang — personal portfolio. Next.js (App Router) + TypeScript + Tailwind.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
